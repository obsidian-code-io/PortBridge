# Copy to .env and fill in. Never commit real values.

# REQUIRED: admin token, >= 16 characters. Container refuses to boot otherwise.
ADMIN_TOKEN=

# Optional overrides (defaults shown).
PORT=8080
PORT_RANGE=30000-30999
DEFAULT_TTL_MINUTES=60
MAX_FORWARDS=50
DATA_DIR=/app/data

# Pin the sidecar image to a digest in production.
# SOCAT_IMAGE=alpine/socat:1.8.0.0@sha256:<pin-me>

# Point at a docker-socket-proxy instead of mounting the raw socket.
# DOCKER_HOST=tcp://docker-socket-proxy:2375
